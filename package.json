{
  "name": "pi-coder-v1",
  "version": "0.1.0",
  "description": "TDD Orchestrator/Worker harness for pi — semi-deterministic coding with strict test-driven development",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "pi-package"
  ],
  "files": [
    "src/**/*.ts",
    "extensions/",
    "agents/",
    "skills/**/*",
    "README.md"
  ],
  "scripts": {
    "test": "node --experimental-strip-types --test 'src/**/*.test.ts' 'extensions/**/*.test.ts'",
    "typecheck": "tsc --noEmit"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.75.5",
    "@earendil-works/pi-coding-agent": "^0.75.5",
    "@types/node": "^25.9.1",
    "typebox": "^1.1.38"
  }
}
